# PeerTranslate Configuration
# Get your free Gemini API key at: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
SIMILARITY_THRESHOLD=0.85
MAX_RETRIES=2

# Turso/LibSQL Cloud Database (optional — falls back to local SQLite if empty)
# Create a free database at: https://turso.tech
# Run: turso db show your-db-name --url
# Run: turso db tokens create your-db-name
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
